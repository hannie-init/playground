#!/bin/sh
# Run Spotless to auto-format staged Java files before commit.
# If formatting changes are made, the commit is aborted so you can review and re-stage.

echo "Running Spotless (Google Java Format)..."

./gradlew spotlessApply --quiet

if ! git diff --quiet; then
    echo ""
    echo "Spotless reformatted some files. Please review and re-stage:"
    echo ""
    git diff --name-only
    echo ""
    echo "  git add <files> && git commit"
    echo ""
    exit 1
fi

echo "Spotless check passed."
exit 0